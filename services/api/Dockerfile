FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source into /app/api/ so "api.main" is importable
COPY . /app/api/

# Move alembic files to /app so alembic.ini and /app/alembic/ are at the working dir root
RUN mv /app/api/alembic /app/alembic && mv /app/api/alembic.ini /app/alembic.ini

CMD ["sh", "-c", "alembic upgrade head && uvicorn api.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
