# ── Google AI Studio (LLM) ────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# ── PostgreSQL ────────────────────────────────────────────
# Local dev (docker-compose):
DATABASE_URL=postgresql://postgres:postgres@db:5432/hireiq
# Railway: set to the Railway PostgreSQL plugin URL (auto-injected as DATABASE_URL)

# ── Service URLs ──────────────────────────────────────────
# Local dev (docker-compose):
AGENT_SERVICE_URL=http://agent-service:8001
# Railway: set to https://<your-agents-service>.up.railway.app

# ── Frontend ──────────────────────────────────────────────
# Vercel: set VITE_API_URL to https://<your-api-service>.up.railway.app
VITE_API_URL=http://localhost:8000

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production

# ── LangSmith Observability (optional) ────────────────────
# Sign up free at https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hireiq

# ── Google OAuth (optional) ───────────────────────────────
# Get from https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ── App ───────────────────────────────────────────────────
ENVIRONMENT=development
